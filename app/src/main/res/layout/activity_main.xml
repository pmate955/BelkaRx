<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="0dp"
    tools:context=".MainActivity">

    <ToggleButton
        android:id="@+id/toggleControlsButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:textOn="▲"
        android:textOff="▲"
        android:checked="false"
        android:textSize="14sp"
        android:padding="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topBarCenterContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="@+id/toggleControlsButton"
        app:layout_constraintEnd_toStartOf="@+id/startStopButton"
        app:layout_constraintStart_toEndOf="@+id/toggleControlsButton"
        app:layout_constraintTop_toTopOf="@+id/toggleControlsButton" />

    <ToggleButton
        android:id="@+id/startStopButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:textOn="Stop"
        android:textOff="Start"
        android:checked="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toggleControlsButton">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="0dp"
            android:text="Status: Idle"
            android:textSize="12sp"
            android:textColor="@android:color/holo_blue_dark" />

        <LinearLayout
            android:id="@+id/dropdownDynamicArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/mainToggleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical">

            <ToggleButton
                android:id="@+id/swapIQToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:drawableStart="@drawable/ic_toggle_swap_iq"
                android:drawablePadding="4dp"
                android:textOff="Swap I/Q"
                android:textOn="Swap I/Q" />

            <ToggleButton
                android:id="@+id/zoomToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:checked="false"
                android:contentDescription="Zoom"
                android:drawableStart="@drawable/ic_toggle_zoom"
                android:drawablePadding="0dp"
                android:minWidth="48dp"
                android:textOff="Zoom"
                android:textOn="Zoom" />

            <ToggleButton
                android:id="@+id/showSpectrumToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:checked="false"
                android:contentDescription="Spectrum"
                android:drawableStart="@drawable/ic_toggle_spectrum"
                android:drawablePadding="0dp"
                android:minWidth="48dp"
                android:textOff="Spectrum"
                android:textOn="Spectrum" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/spectrumOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical">

            <ToggleButton
                android:id="@+id/spectrumFilledToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:contentDescription="Filled spectrum"
                android:drawableStart="@drawable/ic_toggle_filled"
                android:drawablePadding="0dp"
                android:minWidth="48dp"
                android:textOff="Fill"
                android:textOn="Fill" />

            <ToggleButton
                android:id="@+id/spectrumConstantColorToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:checked="false"
                android:contentDescription="Monochrome spectrum"
                android:drawableStart="@drawable/ic_toggle_monochrome"
                android:drawablePadding="0dp"
                android:minWidth="48dp"
                android:textOff="Mono"
                android:textOn="Mono" />

        </LinearLayout>

    </LinearLayout>

    <SurfaceView
        android:id="@+id/waterfallSurface"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/controlsContainer" />

    <!-- Views to be moved dynamically -->
    <LinearLayout
        android:id="@+id/spinnerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        tools:ignore="MissingConstraints">

        <Spinner
            android:id="@+id/deviceSpinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/colorScaleSpinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/sensitivityView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">
        <TextView
            android:id="@+id/sensitivityLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="2dp"
            android:text="Sensitivity"
            android:textColor="@android:color/white" />
        <SeekBar
            android:id="@+id/sensitivitySeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:max="130"
            android:progress="75" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/contrastView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">
        <TextView
            android:id="@+id/contrastLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="2dp"
            android:text="Contrast"
            android:textColor="@android:color/white" />
        <SeekBar
            android:id="@+id/contrastSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:max="300"
            android:progress="100" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>